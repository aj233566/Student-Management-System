<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Student</title>
    <link rel="stylesheet" href="/new.css">
</head>

<body>
    <h2>Add Student</h2>
    <form action="/students/new" method="post">

        <label for="fullName">Full Name</label>
        <input required type="text" id="fullName" name="fullName" placeholder="Enter Full Name">

        <label for="fatherName">Father's Name</label>
        <input required type="text" id="fatherName" name="fatherName" placeholder="Enter Father's Name">

        <label for="motherName">Mother's Name</label>
        <input required type="text" id="motherName" name="motherName" placeholder="Enter Mother's Name">

        <label for="gender">Gender</label>
        <select name="gender" required aria-placeholder="Select Gender">
            <option value="">Select Gender</option>
            <option value="Male">Male</option>
            <option value="Female">Female</option>
        </select>

        <label for="dob">Date of Birth</label>
        <input type="date" id="dob" name="dob" required>

        <label for="cls">Class</label>
        <select name="cls" required>
            <option value="">Select Class</option>
            <% for(let i=1; i<=12; i++) { %>
                <option value="<%= i %>">
                    <%= i %>
                </option>
                <% } %>
        </select>
        <label for="section">Section</label>
        <select name="section" required>
            <option value="">Select Section</option>
            <option value="A">A</option>
            <option value="B">B</option>
            <option value="C">C</option>
            <option value="D">D</option>
            <option value="E">E</option>
            <option value="F">F</option>
        </select>

        <label for="address">Address</label>
        <input required type="text" id="address" name="address" placeholder="Enter Address">

        <label for="contactNo">Contact No:</label>
        <input required type="text" id="contactNo" name="contactNo" placeholder="Enter Contact No">
        <button type="submit">Submit</button>
    </form>
</body>

</html>