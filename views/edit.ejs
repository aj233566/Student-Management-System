<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student Details</title>
    <link rel="stylesheet" href="/edit.css">
</head>

<body>
    <h1>Edit Details</h1>

    <form action="/students/<%= student.id %>?_method=PATCH" method="post">

        <label for="fullName">Update Name</label>
        <input type="text" id="fullName" name="fullName" value="<%= student.fullName %>" placeholder="Update Name">

        <label for="motherName">Update Mother Name</label>
        <input type="text" id="motherName" name="motherName" value="<%= student.motherName %>" placeholder="Update Mother's Name">

        <label for="fatherName">Update Father Name</label>
        <input type="text" id="fatherName" name="fatherName" value="<%= student.fatherName %>" placeholder="Update Father's Name">

        <label for="address">Update Address</label>
        <input type="text" id="address" name="address" value="<%= student.address %>" placeholder="Update Address">

        <label for="contactNo">Update Contact No:</label>
        <input type="text" id="contactNo" name="contactNo" value="<%= student.contactNo %>" placeholder="Update Contact No">

        <label for="dob">Update Date of Birth</label>
        <input type="date" id="dob" name="dob" value="<%= student.dob.toISOString().split('T')[0] %>">

        <label for="section">Update Section</label>
        <select name="section">
            <option value="A" <%= student.section === "A" ? "selected" : "A" %>>A</option>
            <option value="B" <%= student.section === "B" ? "selected" : "B" %>>B</option>
            <option value="C" <%= student.section === "C" ? "selected" : "C" %>>C</option>
            <option value="D" <%= student.section === "D" ? "selected" : "D" %>>D</option>
            <option value="E" <%= student.section === "E" ? "selected" : "E" %>>E</option>
            <option value="F" <%= student.section === "F" ? "selected" : "F" %>>F</option>
        </select>

        <button type="submit">UPDATE</button>
    </form>
</body>

</html>
